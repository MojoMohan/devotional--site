<%- include('partials/head', { title }) %>
<div class="cms-shell">
  <%- include('partials/sidebar', { active: 'store' }) %>
  <main class="main">
    <div class="topbar">
      <div>
        <h1><%= title %></h1>
        <p>Manage store item details.</p>
      </div>
      <div class="actions">
        <a class="btn btn-outline" href="/cms/store-items">Back to list</a>
      </div>
    </div>

    <div class="card">
      <h2>Item details</h2>
      <form method="post" action="<%= action %>" class="form-grid">
        <div>
          <label>Name</label>
          <input name="name" value="<%= item ? item.name : '' %>" required />
        </div>
        <div>
          <label>Category</label>
          <select name="category">
            <option value="">Select category</option>
            <option <%= item && item.category === 'Brass Idols' ? 'selected' : '' %>>Brass Idols</option>
            <option <%= item && item.category === 'Pooja Items' ? 'selected' : '' %>>Pooja Items</option>
            <option <%= item && item.category === 'Rudraksha' ? 'selected' : '' %>>Rudraksha</option>
            <option <%= item && item.category === 'Incense & Dhoop' ? 'selected' : '' %>>Incense & Dhoop</option>
            <option <%= item && item.category === 'Spiritual Clothing' ? 'selected' : '' %>>Spiritual Clothing</option>
            <option <%= item && item.category === 'Copper Items' ? 'selected' : '' %>>Copper Items</option>
            <option <%= item && item.category === 'Spiritual Jewelry' ? 'selected' : '' %>>Spiritual Jewelry</option>
          </select>
        </div>
        <div>
          <label>Price (INR)</label>
          <input name="price" type="number" min="0" step="1" value="<%= item && item.price != null ? item.price : '' %>" />
        </div>
        <div>
          <label>Image URL</label>
          <input name="image_url" value="<%= item ? item.image_url : '' %>" placeholder="https://" />
        </div>
        <div style="grid-column: 1 / -1;">
          <label>Description</label>
          <textarea name="description"><%= item ? item.description : '' %></textarea>
        </div>
        <div>
          <label>Status</label>
          <select name="is_active">
            <option value="1" <%= !item || item.is_active ? 'selected' : '' %>>Active</option>
            <option value="0" <%= item && !item.is_active ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>
        <div style="grid-column: 1 / -1;" class="actions">
          <button class="btn btn-primary" type="submit">Save</button>
          <a class="btn btn-outline" href="/cms/store-items">Cancel</a>
        </div>
      </form>
    </div>
  </main>
</div>
<%- include('partials/foot') %>

